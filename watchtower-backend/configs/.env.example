# 复制为 .env（不要提交 .env 本身），供两个服务在部署时注入敏感配置。
# docker-compose / systemd EnvironmentFile / K8s Secret 均可直接使用本文件的变量名。

# ---- 两个服务共用：登录认证 ----
# JWT 签名密钥，两个服务必须配置完全相同的值，否则 SSO（登录状态互通）会失效
AUTH_JWT_SECRET=change-me-to-a-long-random-string
# 管理员账号
ADMIN_USER=admin
# 管理员密码的 bcrypt 哈希（不要直接写明文密码）；可用 htpasswd/自写小工具生成
ADMIN_PASSWORD_HASH=

# ---- 可选：覆盖统一配置文件路径（默认自动探测 ../configs/config.yaml / configs/config.yaml）----
CONFIG_PATH=

# ---- lvneng(dashboard) 独有：可选覆盖 ----
LISTEN_ADDR=
PROBE_INTERVAL=
